{
  "name": "skyddsrum-finder",
  "version": "1.0.0",
  "description": "Hitta närmaste skyddsrum i Stockholms län / Find the nearest shelter in Stockholm County",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "start-static": "node server-static.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server.js",
    "client": "npm start --prefix client",
    "update-data": "node scripts/download-and-process-new.js",
    "update-data-old": "node scripts/download-and-process.js",
    "heroku-postbuild": "NPM_CONFIG_PRODUCTION=false npm install --prefix client && npm run build --prefix client",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "skyddsrum",
    "shelter",
    "stockholm",
    "emergency",
    "msb",
    "sweden"
  ],
  "author": "AI Assistant",
  "license": "MIT",
  "dependencies": {
    "adm-zip": "^0.5.16",
    "axios": "^1.5.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "proj4": "^2.19.5",
    "shapefile": "^0.6.6",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.1"
  },
  "engines": {
    "node": "18.x",
    "npm": "9.x"
  }
}
